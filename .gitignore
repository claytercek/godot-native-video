# Godot auto generated files
*.gen.*
.godot/
!project/.godot/

# Zig 0.16 project-local dependency store
zig-pkg/
project/.godot/*
!project/.godot/extension_list.cfg

# Zig build outputs
.zig-cache/
zig-out/

# Built extension library — keep the .gdextension manifest.
project/lib/

# Generated test media — regenerate with tools/gen_*.sh, never committed.
tests/fixtures/

# Other stuff
*.log

# VSCode
.vscode/*
!.vscode/extensions.json
.DS_Store

# Jetbrains
.idea/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
