# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

# Real-clip format matrix — binary encoded clips stored via Git LFS.
# (Generated by tools/gen_clip_matrix.sh; test-only, never shipped at runtime.)
# The manifests (matrix.json / matrix.list) are plain text and stay out of LFS.
tests/fixtures/matrix/*.mp4 filter=lfs diff=lfs merge=lfs -text
tests/fixtures/matrix/*.mov filter=lfs diff=lfs merge=lfs -text
tests/fixtures/matrix/matrix.json text eol=lf
tests/fixtures/matrix/matrix.list text eol=lf
