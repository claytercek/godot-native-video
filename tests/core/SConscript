#!/usr/bin/env python
# Standalone build script for Engine Core unit tests.
# Intentionally does NOT depend on godot-cpp or any Godot headers.
# Build with:  scons -f tests/core/SConscript  (or via the root alias below)
# Run  with:   ./bin/core_tests  (or via CTest if integrated)
Import("env")  # injected by the top-level SConstruct core_tests target

test_env = env.Clone()

# C++20, warnings as errors
test_env.Append(CXXFLAGS=["-std=c++20", "-Wall", "-Wextra", "-Wpedantic"])

# Include paths: core source + vendored test framework
test_env.Append(CPPPATH=[
    "#src/core",
    "#tests/core/vendor",
])

sources = [
    "test_frame_queue.cpp",
    "test_clock.cpp",
]

core_tests = test_env.Program(
    "#bin/core_tests",
    sources,
)

Return("core_tests")
