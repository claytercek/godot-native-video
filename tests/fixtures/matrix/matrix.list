# Real-clip format matrix — plain-text mirror of matrix.json, parsed by the
# headless backend coverage tests (no JSON dependency in the test binaries).
# Keep in sync with matrix.json and tools/gen_clip_matrix.sh.
#
# Columns (whitespace-separated):
#   file  width  height  fps  frames  audio_channels  audio_rate
# Lines starting with '#' and blank lines are ignored.
h264_30_mp4.mp4 320 240 30 30 2 48000
h264_24_mov.mov 320 240 24 24 2 48000
h264_60_mp4.mp4 320 240 60 60 2 48000
hevc_30_mp4.mp4 320 240 30 30 2 48000
hevc_24_mov.mov 320 240 24 24 2 48000
