; Godot 4.4 demo project for the Native Video GDExtension.
; A Forward+ (RenderingDevice) renderer is required — the zero-copy present
; path has no CPU fallback and does not support Compatibility/OpenGL.

config_version=5

[application]

config/name="Native Video — Smoke Test"
run/main_scene="res://scenes/smoke.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")

[rendering]

renderer/rendering_method="forward_plus"
